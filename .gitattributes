* text=auto
encoding=UTF-8

# Ensure shell scripts use LF line endings (important for cross-platform builds)
src/Compilers/CSharp/CscCore/csc text eol=lf
src/Compilers/VisualBasic/VbcCore/vbc text eol=lf

# Set line endings for Visual Studio files to CRLF on Windows
*.sln text eol=crlf
*.csproj text eol=crlf
*.vbproj text eol=crlf
*.vcxproj text eol=crlf
*.dbproj text eol=crlf
*.fsproj text eol=crlf
*.lsproj text eol=crlf
*.wixproj text eol=crlf
*.modelproj text eol=crlf
*.sqlproj text eol=crlf
*.wmaproj text eol=crlf
*.xproj text eol=crlf
*.props text eol=crlf
*.filters text eol=crlf
*.vcxitems text eol=crlf

# Treat project files as mergeable (avoid diff markers in conflicts)
*.sln merge=union
*.csproj merge=union
*.vbproj merge=union
*.vcxproj merge=union
*.dbproj merge=union
*.fsproj merge=union
*.lsproj merge=union
*.wixproj merge=union
*.modelproj merge=union
*.sqlproj merge=union
*.wmaproj merge=union
*.xproj merge=union
*.props merge=union
*.filters merge=union
*.vcxitems merge=union

